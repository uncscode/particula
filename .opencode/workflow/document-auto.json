{
  "name": "document-auto",
  "version": "2.3.0",
  "description": "Auto documentation workflow: plan and update documentation, then review with a conditional fix pass before branch-accumulation shipping.",
  "workflow_type": "document",
  "steps": [
    {
      "type": "workflow",
      "name": "Plan",
      "workflow_name": "plan-work-multireview"
    },
    {
      "type": "workflow",
      "name": "Document",
      "workflow_name": "documentation-update"
    },
    {
      "type": "workflow",
      "name": "Review",
      "workflow_name": "review-auto"
    },
    {
      "type": "agent",
      "name": "Plan Fix",
      "agent": "review-fix-planner",
      "prompt": "$ARGUMENTS --adw-id ${adw_id}",
      "model": "base",
      "timeout": 900,
      "retry": {
        "max_retries": 1,
        "initial_delay": 5.0,
        "backoff": 2.0
      },
      "condition": {
        "if_condition": "state.request_fix == True"
      }
    },
    {
      "type": "agent",
      "name": "Fix",
      "agent": "adw-build-fix",
      "prompt": "$ARGUMENTS --adw-id ${adw_id}",
      "model": "base",
      "timeout": 3600,
      "retry": {
        "max_retries": 1,
        "initial_delay": 10.0,
        "backoff": 2.0
      },
      "condition": {
        "if_condition": "state.request_fix == True",
        "skip_if": "state.fix_completed == True"
      }
    },
    {
      "type": "workflow",
      "name": "Fix-Validate",
      "workflow_name": "adw-validate",
      "condition": {
        "if_condition": "state.request_fix == True"
      }
    },
    {
      "type": "workflow",
      "name": "Fix-Polish",
      "workflow_name": "adw-polish",
      "condition": {
        "if_condition": "state.request_fix == True"
      }
    },
    {
      "type": "workflow",
      "name": "Fix-Test",
      "workflow_name": "test",
      "condition": {
        "if_condition": "state.request_fix == True"
      }
    },
    {
      "type": "workflow",
      "name": "Fix-Format",
      "workflow_name": "adw-format",
      "condition": {
        "if_condition": "state.request_fix == True"
      }
    },
    {
      "type": "workflow",
      "name": "Ship",
      "workflow_name": "ship-auto"
    }
  ]
}
