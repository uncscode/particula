{
  "$schema": "https://opencode.ai/config.json",

  // Per-repo OpenCode provider example for OpenAI.
  //
  // Keep this file committed as an example only. ChatGPT Plus/Pro OAuth
  // credentials are not configured here. They are stored in OpenCode auth data
  // after `/connect`, or supplied per repo with OPENCODE_AUTH_CONTENT.

  // Use an OpenAI-backed model for this repository. Adjust the model ID to a
  // model available to your OpenAI account.
  "model": "openai/gpt-5.1-codex-max",
  "small_model": "openai/gpt-5.1-codex-mini",

  "enabled_providers": ["openai"],

  "provider": {
    "openai": {
      "options": {
        // Optional. Leave this as the default OpenAI API endpoint unless your
        // team uses a compatible gateway or proxy.
        "baseURL": "https://api.openai.com/v1"
      }
    }
  }
}
